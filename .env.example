# OpenAI Compatible API settings
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_BASE_URL=https://api.openai-proxy.org/v1
OPENAI_COMPATIBLE_MODEL=gpt-5.4-mini
USE_LOCAL_MODEL=api

# RAG backend: chroma | elasticsearch
RAG_BACKEND=chroma

# Elasticsearch (required when RAG_BACKEND=elasticsearch)
ES_URL=
ES_API_KEY=
ES_INDEX=finance_rag_chunks

# Optional RAG knobs
# RAG_ENABLED=true
# RAG_HYBRID_ENABLED=true
# RAG_RERANK_ENABLED=true
# RAG_CANDIDATE_K=20
